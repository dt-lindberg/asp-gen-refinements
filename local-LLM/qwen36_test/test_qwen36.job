#!/bin/bash

#SBATCH --job-name=Qwen36Test
#SBATCH --partition=gpu_h100
#SBATCH --time=01:30:00
#SBATCH --gpus=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=16
#SBATCH --chdir=/home/dlindberg/Projects/asp-gen-refinements-V2
#SBATCH --output=local-LLM/qwen36_test/outputs/slurm_%A.out

module purge
module load 2025
module load CUDA/12.8.0
module load Python/3.13.5-GCCcore-14.3.0

mkdir -p local-LLM/qwen36_test/outputs

source local-LLM/qwen36_test/.venv/bin/activate

export PYTHONPATH="local-LLM/qwen36_test:${PYTHONPATH:-}"
export LOG_LEVEL="${LOG_LEVEL:-info}"

python3 local-LLM/qwen36_test/test.py

echo ""
echo "Exiting job"
