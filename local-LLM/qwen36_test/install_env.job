#!/bin/bash

#SBATCH --job-name=Qwen36Install
#SBATCH --partition=rome
#SBATCH --time=01:30:00
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=16
#SBATCH --chdir=/home/dlindberg/Projects/asp-gen-refinements-V2
#SBATCH --output=local-LLM/qwen36_test/outputs/install_%A.out

module purge
module load 2025
module load CUDA/12.8.0
module load Python/3.13.5-GCCcore-14.3.0

mkdir -p local-LLM/qwen36_test/outputs

VENV=local-LLM/qwen36_test/.venv
REPO_ID="Qwen/Qwen3.6-35B-A3B-FP8"

echo "=== [1/3] Create venv at $VENV ==="
if [ ! -d "$VENV" ]; then
    python3 -m venv "$VENV"
fi
source "$VENV/bin/activate"
python3 -m pip install --upgrade pip

echo ""
echo "=== [2/3] Install vllm>=0.19.0 + huggingface_hub ==="
pip install --no-cache-dir "vllm>=0.19.0"
pip install --no-cache-dir "huggingface_hub[cli]"

echo ""
echo "Installed vLLM version:"
python3 -c "import vllm; print(vllm.__version__)"

echo ""
echo "=== [3/3] Pre-download $REPO_ID safetensors ==="
python3 - <<PY
from huggingface_hub import snapshot_download
path = snapshot_download(
    repo_id="$REPO_ID",
    allow_patterns=["*.safetensors", "*.json", "*.txt", "tokenizer*", "*.py"],
)
print(f"Downloaded to: {path}")
PY

echo ""
echo "Exiting install job"
