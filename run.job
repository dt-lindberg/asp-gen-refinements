#!/bin/bash

#SBATCH --job-name=ASPGen
#SBATCH --partition=gpu_a100
#SBATCH --time=04:00:00
#SBATCH --gpus=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=18
#SBATCH --chdir=/home/dlindberg/Projects/asp-gen-refinements-V2
#SBATCH --output=outputs/slurm_output_%A.out

module purge
module load 2025
module load CUDA/12.8.0
module load Python/3.13.5-GCCcore-14.3.0

mkdir -p outputs caches mistakes

# Hardware monitor
HW_LOG="local-LLM/outputs/hw_monitor_${SLURM_JOB_ID}.csv"
bash local-LLM/monitor_hw.sh "$HW_LOG" 10 &
MONITOR_PID=$!

source /home/dlindberg/Projects/asp-gen-refinements/.venv/bin/activate

# Deterministic vLLM scheduling for reproducibility
export VLLM_ENABLE_V1_MULTIPROCESSING=0
export LOG_DIR=/home/dlindberg/Projects/asp-gen-refinements-V2/logs

python3 main.py \
    --debug \
    --dataset_name train \
    --num 3 \
    --engine qwen3-30b-local \
    --seed "${RUN_SEED:-132}" \

# Stop monitor and print hardware report
kill "$MONITOR_PID" 2>/dev/null
wait "$MONITOR_PID" 2>/dev/null
python3 local-LLM/summarize_hw.py "$HW_LOG"

echo ""
echo "Exiting job"
