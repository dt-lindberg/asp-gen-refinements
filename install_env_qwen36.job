#!/bin/bash

#SBATCH --job-name=EnvDown36
#SBATCH --partition=rome
#SBATCH --time=01:30:00
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=16
#SBATCH --output=slurm_output_%A.out

module purge
module load 2025
module load Python/3.13.5-GCCcore-14.3.0
module load CMake/4.0.3-GCCcore-14.3.0

cd $HOME/Projects/asp-gen-refinements

VENV=.venv_qwen36
REPO_ID="Qwen/Qwen3.6-35B-A3B-FP8"

echo "=== [1/4] Create venv at $VENV ==="
if [ ! -d "$VENV" ]; then
    python3 -m venv "$VENV"
fi
source "$VENV/bin/activate"
python3 -m pip install --upgrade pip

echo ""
echo "=== [2/4] Install vLLM 0.19+ and huggingface_hub ==="
pip install --no-cache-dir -r requirements_vllm_qwen36.txt

echo ""
echo "Installed vLLM version:"
python3 -c "import vllm; print(vllm.__version__)"

echo ""
echo "=== [3/4] Install remaining pipeline deps (clingo et al.) ==="
pip install setuptools wheel scikit-build
export CMAKE_ARGS="-DCMAKE_POLICY_VERSION_MINIMUM=3.5"
pip install --no-deps --no-build-isolation -r requirements.txt

echo ""
echo "=== [4/4] Pre-download $REPO_ID safetensors ==="
python3 - <<PY
from huggingface_hub import snapshot_download
path = snapshot_download(
    repo_id="$REPO_ID",
    allow_patterns=["*.safetensors", "*.json", "*.txt", "tokenizer*", "*.py"],
)
print(f"Downloaded to: {path}")
PY

echo ""
echo "[SLURM] Exiting"
