#!/bin/bash

#SBATCH --job-name=QwenRun
#SBATCH --partition=gpu_a100
#SBATCH --time=01:00:00
#SBATCH --gpus=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=18
#SBATCH --output=slurm_output_%A.out

module purge
module load 2025
module load CUDA/12.8.0
module load Python/3.13.5-GCCcore-14.3.0

cd $HOME/Projects/asp-gen-refinements/testing

# --- hardware monitor ---
HW_LOG="hw_monitor_${SLURM_JOB_ID}.csv"
bash monitor_hw.sh "$HW_LOG" 10 &
MONITOR_PID=$!
# -----------------------

RUN_TYPE="normal"

echo "Running local LLM test..."
if [ "$RUN_TYPE" = "normal" ]; then
	source .venv/bin/activate
	python3 local_llm_test.py
else
	source .venv_unsloth/bin/activate
	python3 local_llm_test_unsloth.py
fi

# --- stop monitor and print report ---
kill "$MONITOR_PID" 2>/dev/null
wait "$MONITOR_PID" 2>/dev/null
python3 summarize_hw.py "$HW_LOG"
# -------------------------------------

echo ""
echo "Exiting job"
