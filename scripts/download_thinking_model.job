#!/bin/bash

#SBATCH --job-name=DownloadThinkingModel
#SBATCH --partition=rome
#SBATCH --time=01:00:00
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=4
#SBATCH --chdir=/home/dlindberg/Projects/asp-gen-refinements
#SBATCH --output=outputs/download_thinking_model_%A.out

module purge
module load 2025
module load Python/3.13.5-GCCcore-14.3.0

mkdir -p outputs

source .venv/bin/activate

python3 - <<'EOF'
from huggingface_hub import hf_hub_download
print("Downloading Qwen3-30B-A3B-Thinking-2507-Q4_K_M.gguf ...", flush=True)
path = hf_hub_download(
    repo_id="unsloth/Qwen3-30B-A3B-Thinking-2507-GGUF",
    filename="Qwen3-30B-A3B-Thinking-2507-Q4_K_M.gguf",
)
print(f"Downloaded to: {path}", flush=True)
EOF
